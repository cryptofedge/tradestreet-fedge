# ============================================
# FEDGE 2.O — Environment Configuration
# Copy to .env and fill in your values
# ============================================

# App
NODE_ENV=development
APP_VERSION=2.0.1
PORT=3000

# Database
DATABASE_URL=postgresql://fedge:fedge@localhost:5432/tradestreet
REDIS_URL=redis://localhost:6379

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES=900        # 15 minutes
JWT_REFRESH_EXPIRES=2592000   # 30 days

# Anthropic (FEDGE Brain)
ANTHROPIC_API_KEY=sk-ant-...
FEDGE_BRAIN_MODEL=claude-sonnet-4
FEDGE_MAX_TOKENS=2000

# Alpaca Markets
ALPACA_API_KEY=PK...
ALPACA_API_SECRET=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Use paper for dev
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_OAUTH_CLIENT_ID=...
ALPACA_OAUTH_CLIENT_SECRET=...
ALPACA_OAUTH_REDIRECT_URI=fedge://oauth/callback

# RevenueCat
REVENUECAT_SECRET_KEY=sk_...
REVENUECAT_WEBHOOK_SECRET=...

# Encryption (for storing brokerage tokens)
ENCRYPTION_KEY=32_char_hex_string_here
ENCRYPTION_IV=16_char_hex_string_here

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=...

# Sentry (Error Tracking)
SENTRY_DSN=https://...@sentry.io/...

# Rate Limiting
RATE_LIMIT_FREE_RPM=60
RATE_LIMIT_PRO_RPM=300
RATE_LIMIT_FREE_SIGNALS_PER_DAY=1
RATE_LIMIT_PRO_SIGNALS_PER_DAY=999999

# FEDGE Branding
FEDGE_BRAND_NAME=FEDGE 2.O
FEDGE_BRAND_AUTHOR=Rafael Fellito Rodriguez Jr.
FEDGE_BRAND_COMPANY=Eclat Universe
