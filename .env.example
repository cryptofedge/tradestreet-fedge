# ============================================
# FEDGE 2.O — Environment Variables
# Copy to .env and fill in your values
# ============================================

# ---- App ----
NODE_ENV=development
PORT=3000
APP_VERSION=2.0.1

# ---- Database ----
DATABASE_URL=postgresql://fedge:fedge@localhost:5432/tradestreet

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT (RS256 — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem) ----
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES=900
JWT_REFRESH_EXPIRES=2592000

# ---- Alpaca (Paper Trading) ----
# Get keys at: https://app.alpaca.markets/paper-trading
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_API_SECRET=your_alpaca_paper_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_DATA_URL=https://data.alpaca.markets/v2

# ---- Anthropic (FEDGE Brain) ----
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
FEDGE_BRAIN_MODEL=claude-sonnet-4-6
FEDGE_MAX_TOKENS=2000

# ---- Rate Limits ----
RATE_LIMIT_PRO_ADVISOR_PER_DAY=100

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
